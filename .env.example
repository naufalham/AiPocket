# ===========================================
# AiPocket - Environment Configuration
# ===========================================
# Copy this file: cp .env.example .env
# Fill in your values below.

# Deployer / Operator private key
PRIVATE_KEY=your_private_key_here

# ===========================================
# Polkadot Hub Testnet (Primary — Hackathon)
# ===========================================
# Passet Hub (Polkadot Hub Testnet) — Chain ID: 420420421
POLKADOT_HUB_TESTNET_RPC_URL=https://testnet-passet-hub-eth-rpc.polkadot.io

# ===========================================
# Base Sepolia (Legacy — previous deployment)
# ===========================================
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
BASESCAN_API_KEY=your_basescan_api_key

# ===========================================
# Contract Addresses (update after deployment)
# ===========================================
AGENT_IDENTITY_ADDRESS=0x_deployed_address
AGENT_REPUTATION_ADDRESS=0x_deployed_address
AGENT_REGISTRY_ADDRESS=0x_deployed_address
PREDICTION_MARKET_ADDRESS=0x_deployed_address
REWARD_DISTRIBUTOR_ADDRESS=0x_deployed_address
AUTO_SETTLER_ADDRESS=0x_deployed_address

# ===========================================
# AI Automation Bot
# ===========================================
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================================
# Frontend (prefix with NEXT_PUBLIC_)
# ===========================================
NEXT_PUBLIC_AGENT_IDENTITY_ADDRESS=0x_deployed_address
NEXT_PUBLIC_AGENT_REPUTATION_ADDRESS=0x_deployed_address
NEXT_PUBLIC_AGENT_REGISTRY_ADDRESS=0x_deployed_address
NEXT_PUBLIC_PREDICTION_MARKET_ADDRESS=0x_deployed_address
NEXT_PUBLIC_REWARD_DISTRIBUTOR_ADDRESS=0x_deployed_address
NEXT_PUBLIC_API_URL=http://localhost:3001
